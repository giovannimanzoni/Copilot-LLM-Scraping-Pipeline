{
  	"name": "llm-scraping-coordinator",
  	"license": "GNU GENERAL PUBLIC LICENSE Version 3",
	"version": "1.0.0",
	"type": "module",
	"author": "Giovanni Manzoni <dev@giovannimanzoni.com> (https://www.giovannimanzoni.com)",
	"scripts": {
		"coordinatorTypeCheck": "node_modules/.bin/tsc --noEmit",
		"coordinatorLint": "node_modules/.bin/eslint src/",
		"coordinatorTypeCheckLint": "yarn run coordinatorTypeCheck && yarn run coordinatorLint",
		"oldDev": "node --watch --import tsx/esm src/coordinator.mts",
		"dev": "node_modules/.bin/tsc && node_modules/.bin/tsx watch --import ./src/instrument.mts src/coordinator.mts",
		"clean": "rm -rf ./dist",
		"build": "yarn clean && tsc && tsc-alias",
		"start": "node --import ./dist/instrument.mjs dist/coordinator.mjs"
	},
	"engines": {
		"node": "24.14.1"
	},
	"dependencies": {
		"@koa/router": "^12.0.1",
		"@sentry/node": "^8.0.0",
		"dotenv": "^17.3.1",
		"koa": "^2.15.3",
		"koa-bodyparser": "^4.4.1",
		"koa-logger": "^4.0.0",
		"koa-redis": "^4.0.1",
		"redis": "^5.11.0",
		"tsc-alias": "^1.8.16",
		"tsconfig-paths": "^4.2.0",
		"yaml": "^2.8.3",
		"zod": "^4.3.6"
	},
	"resolutions": {
		"is-generator-function": "1.0.10"
	},
	"devDependencies": {
		"@eslint/eslintrc": "^3.3.5",
		"@eslint/js": "^10.0.1",
		"@types/koa": "^2.15.0",
		"@types/koa-bodyparser": "^4.3.12",
		"@types/koa__router": "^12.0.4",
		"@types/node": "*",
		"@types/validator": "^13.15.10",
		"@typescript-eslint/eslint-plugin": "^8.57.2",
		"@typescript-eslint/parser": "^8.57.2",
		"eslint": "^9.39.2",
		"eslint-config-prettier": "^10.1.8",
		"eslint-config-standard": "^17.1.0",
		"eslint-import-resolver-typescript": "^4.4.4",
		"eslint-plugin-import": "^2.31.0",
		"eslint-plugin-jest": "^29.15.0",
		"eslint-plugin-n": "^17.24.0",
		"eslint-plugin-promise": "^7.2.1",
		"eslint-plugin-simple-import-sort": "^12.1.1",
		"prettier": "^3.8.1",
		"ts-loader": "^9.5.4",
		"ts-node": "^10.9.2",
		"tslib": "^2.8.1",
		"tsx": "^4.7.0",
		"typescript": "^5.4.0",
		"typescript-ioc": "^3.2.2"
	}
}
